# ===================================
# A股自选股智能分析系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实配置
# ===================================

# 自选股列表（逗号分隔，支持沪深两市代码）
# 沪市：600xxx, 601xxx, 603xxx
# 深市：000xxx, 002xxx, 300xxx
# 为空时可由妙想预选池自动补齐；若启用 MX_PRESELECT_PRIORITY，则优先使用妙想预选池
STOCK_LIST=

# 妙想预选池配置（可选）
# 当前默认风格：balanced_attack（进攻平衡）
# 如需切风格，直接把对应模板复制到 MX_PRESELECT_QUERY 即可
# 切换规则：连续 2 个交易日主线清晰、趋势延续强、追强回撤可控 → 切 high_score
# 切换规则：连续 2 个交易日热点轮动快、冲高回落多、进攻票兑现差 → 切 defensive_quality
# 其余大多数不确定阶段默认用 balanced_attack，不做日内来回切换
MX_PRESELECT_PROFILE=
# 优先使用 mx-xuangu 根据自然语言条件生成股票池
MX_PRESELECT_PRIORITY=true
# 方案A：生产主链优先使用 MX_PRESELECT_QUERY；仅当本项为空时才回退到 MX_PRESELECT_PROFILE 模板
# high_score（高分优先，短句版）
# A股 正常交易 非ST 非停牌 股价 < 80 近20日上涨 成交量放大 业绩增长 板块活跃 排除北交所
# balanced_attack（进攻平衡，默认，短句版）
# A股 正常交易 非ST 非停牌 股价 < 50 近20日上涨 成交量放大 净利润增长 ROE较好 板块活跃 排除北交所 排除科创板 排除创业板
# defensive_quality（稳健优先，短句版）
# A股 正常交易 非ST 非停牌 股价 < 50 低估值 高ROE 业绩稳定 经营现金流良好 排除北交所 排除创业板 排除科创板
MX_PRESELECT_QUERY=A股 正常交易 股价 < 50 非ST 非停牌 低估值 高ROE 业绩稳定 经营现金流良好 财务健康 近20日上涨 排除科创板 排除创业板 排除北交所
MX_PRESELECT_LIMIT=20

# 数据源配置
# Tushare Pro Token（可选，从 https://tushare.pro/weborder/#/login?reg=834638 获取）
# 官方模式：只填写 TUSHARE_TOKEN，TUSHARE_API_URL 留空，默认使用 http://api.tushare.pro
# 兼容代理模式：填写代理分发的 key，并把 TUSHARE_API_URL 指向兼容 Tushare HTTP 协议的代理地址
TUSHARE_TOKEN=
TUSHARE_API_URL=
# TickFlow API Key（可选，用于 A 股大盘复盘指数增强；若套餐支持标的池查询，也可增强市场统计）
# TICKFLOW_API_KEY=

# AI 模型配置
# ===================================
# 完整说明：docs/LLM_CONFIG_GUIDE.md
#
# 【快速上手】填一个 API Key 即可运行，系统自动识别模型。
#   Gemini（免费额度）→ 填 GEMINI_API_KEY
#   DeepSeek（性价比高）→ 填 DEEPSEEK_API_KEY
#   AIHubmix（聚合平台）→ 填 AIHUBMIX_KEY
#
# 【进阶】需要多模型 / 多平台 fallback → 配置下方「多渠道」或在 Web 设置页可视化管理。
# ===================================

# --- API Key（填一个即可）---

# Gemini（https://aistudio.google.com）
GEMINI_API_KEY=*** 多 Key 负载均衡：GEMINI_API_KEYS=***

# DeepSeek（https://platform.deepseek.com）
# DEEPSEEK_API_KEY=***
# AIHubmix 聚合（https://aihubmix.com/?aff=CfMq）
# 一个 Key 用 GPT/Claude/Gemini/GLM/Qwen 等模型，无需科学上网
# AIHUBMIX_KEY=

# Anthropic Claude（https://console.anthropic.com）
# ANTHROPIC_API_KEY=***
# OpenAI / 兼容 API
# OPENAI_API_KEY=*** OPENAI_BASE_URL=                     # 第三方 API 地址（中转站/代理），留空用官方

# Ollama 本地模型（无需 API Key，推荐）
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b
#
# 或使用渠道模式：
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# 采样温度（0.0-2.0，默认 0.7；0 确定性最高，2 随机性最高）
# LLM_TEMPERATURE=0.7

# --- 多渠道配置（可选，也可在 Web 设置页配置）---
# 每个渠道独立配置 base_url / api_key / models，支持多 Key 轮询与自动 fallback。
#
# 示例：DeepSeek + Gemini 双渠道
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=***
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# LLM_DEEPSEEK_MODELS=deepseek-chat
# LLM_GEMINI_API_KEYS=***
# LLM_GEMINI_MODELS=gemini-2.5-flash
#
# 示例：自定义 API 端点（第三方代理 / 聚合平台 / 转发站）
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=***
# LLM_MY_PROXY_MODELS=gpt-4o-mini,claude-3-5-sonnet
# LLM_MY_PROXY_PROTOCOL=openai
#
# 示例：Ollama 本地模型（无需 API Key）
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2

# 高级：模型路由 YAML 配置（可选，参考 litellm_config.example.yaml）
# LITELLM_CONFIG=./litellm_config.yaml

# ===================================
# 搜索引擎配置（用于获取股票新闻）
# ===================================
# Bocha API Keys（中文搜索优化，支持AI摘要，支持多个，逗号分隔）
# 获取: https://open.bocha.cn/
# BOCHA_API_KEYS=***
# MiniMax API Key（Coding Plan Web Search，支持多个，逗号分隔）
# 获取: https://platform.minimaxi.com/
# MINIMAX_API_KEYS=***
