# ===================================
# A股自选股智能分析系统 - 环境变量配置模板
# 复制此文件为 .env，并只填写你实际使用的配置。
# 不要把真实密钥或密码提交到仓库。
# ===================================

# ===================================
# 股票池
# ===================================
# 自选股列表，逗号分隔；支持 A 股、港股、美股代码。
# 留空时可由妙想预选池补齐；若 MX_PRESELECT_PRIORITY=true，则优先使用妙想预选池。
STOCK_LIST=

# 妙想预选池（可选）
MX_PRESELECT_PRIORITY=true
MX_PRESELECT_PROFILE=
# 生产主链优先使用 MX_PRESELECT_QUERY；为空时才回退到 MX_PRESELECT_PROFILE 模板。
# high_score: A股 正常交易 非ST 非停牌 股价 < 80 近20日上涨 成交量放大 业绩增长 板块活跃 排除北交所
# balanced_attack: A股 正常交易 非ST 非停牌 股价 < 50 近20日上涨 成交量放大 净利润增长 ROE较好 板块活跃 排除北交所 排除科创板 排除创业板
# defensive_quality: A股 正常交易 非ST 非停牌 股价 < 50 低估值 高ROE 业绩稳定 经营现金流良好 排除北交所 排除创业板 排除科创板
MX_PRESELECT_QUERY=A股 正常交易 股价 < 50 非ST 非停牌 低估值 高ROE 业绩稳定 经营现金流良好 财务健康 近20日上涨 排除科创板 排除创业板 排除北交所
MX_PRESELECT_LIMIT=20

# ===================================
# 数据源
# ===================================
# Tushare 官方模式：只填写 TUSHARE_TOKEN，TUSHARE_API_URL 留空，默认使用 http://api.tushare.pro
# Tushare 兼容代理模式：TUSHARE_TOKEN 填代理分发的 key，TUSHARE_API_URL 填兼容 Tushare HTTP 协议的代理地址。
# TUSHARE_HTTP_TIMEOUT 控制单次 HTTP 请求超时（秒）；代理不稳时可适当下调，避免 stk_factor_pro 重复慢超时。
TUSHARE_TOKEN=
TUSHARE_API_URL=
TUSHARE_HTTP_TIMEOUT=30

# TickFlow 可增强 A 股大盘复盘指数；若套餐支持标的池查询，也可增强市场统计。
TICKFLOW_API_KEY=

# 市场涨跌统计单数据源超时和短 TTL 缓存。慢源超时后继续 fallback，避免拖垮整轮复盘。
MARKET_STATS_FETCH_TIMEOUT_SECONDS=5
MARKET_STATS_CACHE_TTL_SECONDS=120

# ===================================
# LLM / 模型
# ===================================
# 完整说明：docs/LLM_CONFIG_GUIDE.md
# 简单模式：填一个 provider key + 主模型即可；渠道模式：使用 LLM_CHANNELS 及 LLM_<CHANNEL>_*。

# Gemini
GEMINI_API_KEY=
GEMINI_API_KEYS=

# DeepSeek
DEEPSEEK_API_KEY=

# AIHubmix / OpenAI 兼容平台
AIHUBMIX_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Ollama 本地模型示例
OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b

# 主模型与采样温度
LITELLM_MODEL=
LLM_TEMPERATURE=0.7

# 多渠道示例：DeepSeek + Gemini
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# LLM_DEEPSEEK_MODELS=deepseek-chat
# LLM_GEMINI_API_KEYS=
# LLM_GEMINI_MODELS=gemini-2.5-flash

# 自定义 OpenAI 兼容渠道示例
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=
# LLM_MY_PROXY_MODELS=gpt-4o-mini,claude-3-5-sonnet
# LLM_MY_PROXY_PROTOCOL=openai

# YAML 高级路由配置（可选）
LITELLM_CONFIG=

# 视觉模型（截图识别股票代码等功能使用）
VISION_MODEL=
VISION_PROVIDER_PRIORITY=gemini,anthropic,openai

# Agent 策略对话（Web 对话页，可选）
AGENT_MODE=false
AGENT_LITELLM_MODEL=
AGENT_MAX_STEPS=10
AGENT_SKILLS=
AGENT_SKILL_DIR=./strategies
AGENT_ARCH=single
AGENT_ORCHESTRATOR_MODE=standard
AGENT_ORCHESTRATOR_TIMEOUT_S=600
AGENT_RISK_OVERRIDE=true
AGENT_MEMORY_ENABLED=false
AGENT_SKILL_AUTOWEIGHT=true
AGENT_SKILL_ROUTING=auto

# ===================================
# 搜索 / 新闻
# ===================================
# 可按实际账号选择一个或多个搜索源。
BOCHA_API_KEYS=
MINIMAX_API_KEYS=
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true
SEARCH_PROVIDER_PRIORITY=

# 新闻策略窗口：ultra_short(1天) / short(3天) / medium(7天) / long(30天)
# 实际窗口 = min(profile_days, NEWS_MAX_AGE_DAYS)
NEWS_STRATEGY_PROFILE=short
NEWS_MAX_AGE_DAYS=3
BIAS_THRESHOLD=5.0

# 社交情绪数据（可选）
SOCIAL_SENTIMENT_API_KEY=
SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# 通知渠道
# ===================================
# 企业微信机器人
WECHAT_WEBHOOK_URL=

# 飞书群机器人。FEISHU_APP_ID / FEISHU_APP_SECRET 用于飞书应用、Stream Bot 或云文档，不会直接启用群 Webhook 推送。
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
FEISHU_WEBHOOK_KEYWORD=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_STREAM_ENABLED=false
FEISHU_MAX_BYTES=20000

# 邮件。EMAIL_RECEIVERS 留空则默认发给自己。
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=

# 股票分组发往不同邮箱（可选）；STOCK_GROUP_N 建议始终是 STOCK_LIST 的子集。
STOCK_GROUP_1=
EMAIL_GROUP_1=
STOCK_GROUP_2=
EMAIL_GROUP_2=

# 自定义 Webhook（钉钉、Discord、Slack、Bark、自建服务等）
CUSTOM_WEBHOOK_URLS=
CUSTOM_WEBHOOK_BEARER_TOKEN=
WEBHOOK_VERIFY_SSL=true

# 其他推送渠道
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
PUSHPLUS_TOKEN=
PUSHPLUS_TOPIC=
SERVERCHAN3_SENDKEY=

# Markdown 转图片（可选）
MARKDOWN_TO_IMAGE_CHANNELS=
MARKDOWN_TO_IMAGE_MAX_CHARS=15000
MD2IMG_ENGINE=wkhtmltoimage

# ===================================
# 报告 / 运行行为
# ===================================
SINGLE_STOCK_NOTIFY=false
REPORT_TYPE=simple
REPORT_LANGUAGE=zh
REPORT_SUMMARY_ONLY=false
MERGE_EMAIL_NOTIFICATION=false
ANALYSIS_DELAY=0
PREFETCH_REALTIME_QUOTES=true

# Report Engine P0（可选）
REPORT_TEMPLATES_DIR=templates
REPORT_RENDERER_ENABLED=false
REPORT_INTEGRITY_ENABLED=true
REPORT_INTEGRITY_RETRY=1
REPORT_HISTORY_COMPARE_N=0

# 交易日检查；设为 false 或运行时使用 --force-run 可强制执行。
TRADING_DAY_CHECK_ENABLED=true

# ===================================
# Stream / Bot 扩展（可选）
# ===================================
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_STREAM_ENABLED=false
